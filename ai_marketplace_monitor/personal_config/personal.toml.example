# Optional repo-local overlay for personal settings.
#
# Copy this file to `personal.toml` in the same directory and uncomment only
# the values you want to override from ~/.ai-marketplace-monitor/config.toml.
#
# This example is safe to commit. `personal.toml` stays gitignored.

# -----------------------------------------------------------------------------
# AI backends
# -----------------------------------------------------------------------------

[ai.openrouter]
# provider = "openai"
# api_key = "${OPENROUTER_API_KEY}"
# model = "openai/gpt-oss-120b:free"
# base_url = "https://openrouter.ai/api/v1"
# timeout = 120
# max_retries = 3

# [ai.ollama]
# provider = "ollama"
# model = "llama3.1"
# base_url = "http://127.0.0.1:11434/v1"
# timeout = 120

# -----------------------------------------------------------------------------
# Notifications
# Define reusable channels here, then reference them from users or items.
# -----------------------------------------------------------------------------

# [notification.telegram_primary]
# telegram_token = "${TELEGRAM_BOT_TOKEN}"
# telegram_chat_id = "${TELEGRAM_CHAT_ID}"
# message_format = "plain_text"
# with_description = 1
# max_retries = 3
# retry_delay = 10

# [notification.ntfy_local]
# ntfy_server = "https://ntfy.sh"
# ntfy_topic = "facebook-marketplace-scan"
# message_format = "plain_text"

# -----------------------------------------------------------------------------
# Users
# A user can either use explicit channel credentials directly here or use
# `notify_with` to select named entries from the [notification.*] section above.
# -----------------------------------------------------------------------------

[user.default_user]
# notify_with = ["telegram_primary"]
# remind = "1 day"
# max_retries = 3
# retry_delay = 10

# Direct channel fields are also allowed here if you prefer not to use
# [notification.*] sections:
# telegram_token = "${TELEGRAM_BOT_TOKEN}"
# telegram_chat_id = "${TELEGRAM_CHAT_ID}"
# pushover_user_key = "${PUSHOVER_USER_KEY}"
# pushover_token = "${PUSHOVER_APP_TOKEN}"
# pushbullet_token = "${PUSHBULLET_TOKEN}"
# ntfy_server = "https://ntfy.sh"
# ntfy_topic = "facebook-marketplace-scan"
# smtp_server = "smtp.example.com"
# smtp_port = 587
# smtp_username = "alerts@example.com"
# smtp_password = "${SMTP_PASSWORD}"
# email_sender = "alerts@example.com"
# email_receiver = "you@example.com"
# email_subject = "Marketplace match"

# -----------------------------------------------------------------------------
# Marketplace-wide Facebook overrides
# These apply to all Facebook items unless overridden per item.
# -----------------------------------------------------------------------------

[marketplace.facebook]
# username = "${FACEBOOK_EMAIL}"
# password = "${FACEBOOK_PASSWORD}"
# login_wait_time = "2 minutes"
# language = "sv"
# search_city = ["stockholm"]
# city_name = ["Stockholm"]
# radius = [50]
# currency = ["SEK"]
# search_interval = "5 minutes"
# max_search_interval = "15 minutes"
# start_at = ["08:00", "18:00"]
# search_region = ["swe"]
# ai = ["openrouter"]
# notify = ["default_user"]
# min_price = "1000"
# max_price = "20000"
# rating = [3, 3]
# seller_locations = ["Stockholm", "Solna", "Sundbyberg"]
# availability = ["in"]
# condition = ["used_good", "used_like_new"]
# date_listed = [1, 7]
# delivery_method = ["local_pick_up", "shipping"]
# category = "electronics"
# exclude_sellers = ["butikk", "företag"]
# extra_prompt = "Prefer local pickup and Swedish listings."

# -----------------------------------------------------------------------------
# Item-specific overrides
# Use these for your real searches. Each item can override marketplace defaults.
# -----------------------------------------------------------------------------

[item.rtx5060]
# search_phrases = ["rtx 5060", "5060 ti", "geforce 5060"]
# serp_keywords = ["rtx", "5060"]
# keywords = ["16 gb", "16gb", "ti"]
# antikeywords = ["8 gb", "8gb", "laptop", "komplett dator"]
# description = "Looking for an RTX 5060 Ti 16 GB graphics card."
# extra_prompt = "Give 4-5 only when 16 GB VRAM is explicit in title or description."
# rating_prompt = "Be strict about missing VRAM information."
# prompt = "Focus on VRAM, model exactness, and whether this is a GPU-only listing."
# ai = ["openrouter"]
# notify = ["default_user"]
# search_city = ["stockholm"]
# city_name = ["Stockholm"]
# radius = [80]
# currency = ["SEK"]
# search_interval = "3 minutes"
# max_search_interval = "10 minutes"
# max_price = "6000"
# min_price = "2000"
# rating = [4, 4]
# seller_locations = ["Stockholm", "Uppsala"]
# availability = ["in"]
# condition = ["used_like_new", "used_good"]
# date_listed = [1, 7]
# delivery_method = ["local_pick_up", "shipping"]
# category = "electronics"
# exclude_sellers = ["scalper", "broken", "parts only"]

# Another example: complete PC searches can use a different prompt/rating setup.
# [item.gaming_pc]
# search_phrases = ["gaming dator", "gaming pc", "rtx 4070"]
# description = "Gaming desktop with a recent NVIDIA GPU and at least 32 GB RAM."
# ai = ["openrouter"]
# notify = ["default_user"]
# max_price = "18000"
# rating = [3, 4]
# extra_prompt = "Penalize listings that are complete PCs when I am searching for a GPU-only item."

# -----------------------------------------------------------------------------
# Local translations
# Only needed if you want to override or extend built-in translation strings.
# -----------------------------------------------------------------------------

# [translation.sv]
# locale = "Swedish"
# "Description" = "Beskrivning"
# "Condition" = "Skick"
# "Location is approximate" = "Plats är ungefärlig"
