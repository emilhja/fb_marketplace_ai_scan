# Copy to `.env` in the repo root and fill in values. Do not commit `.env`.

# =============================================================================
# OpenRouter (AI listing ratings)
# =============================================================================
# API key from https://openrouter.ai/keys — used for score/conclusion on each listing.
OPENROUTER_API_KEY=

# =============================================================================
# Telegram (optional notifications)
# =============================================================================
# Bot token from @BotFather. Leave empty if you do not use Telegram.
TELEGRAM_BOT_TOKEN=
# Destination chat id (numeric) or @username — chat the bot is allowed to message.
TELEGRAM_CHAT_ID=

# =============================================================================
# AI request pacing
# =============================================================================
# Seconds to sleep after each listing AI evaluation. OpenRouter free tier is often
# ~20 requests/minute → ~3 s average spacing; 4–5 s is a safer default.
AIMM_AI_DELAY_SECONDS=4

# =============================================================================
# Facebook login auto-fill (optional)
# =============================================================================
# If ~/.ai-marketplace-monitor/config.toml has username/password enabled, set these
# so Playwright can fill the Facebook login form.
# FACEBOOK_EMAIL=
# FACEBOOK_PASSWORD=

# =============================================================================
# PostgreSQL — listing sightings + AI cache (see ai_marketplace_monitor/pg_cache.py)
# =============================================================================
# psycopg connection URL (adjust user, password, host, database name).
AIMM_DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/marketplace_scan

# 1 = enable Postgres cache (reads/writes). 0 = disable layer entirely (no dedupe/AI cache).
AIMM_PG_CACHE_ENABLED=1

# 1 = when scraped price differs from last stored price, invalidate cached AI and re-run.
# 0 = keep using cached AI even if price changed (unusual).
AIMM_REEVAL_ON_PRICE_CHANGE=1

# 1 = when listing content hash (title, description, seller, etc.) changes, re-run AI.
# 0 = ignore content changes for cache reuse (unusual).
AIMM_REEVAL_ON_CONTENT_CHANGE=1

# After an evaluation, wait this many minutes before another price/content change
# can force a new AI call; during cooldown, cache may still be reused. 0 = no cooldown.
AIMM_AI_REEVAL_COOLDOWN_MINUTES=0

# Arbitrary label stored/hashed with cache rows — bump when you change rating prompts
# so old evaluations are not treated as valid for the new rubric.
AIMM_PROMPT_VERSION=v1

# =============================================================================
# Facebook search / SERP (local ai_marketplace_monitor/facebook.py)
# =============================================================================
# 1 = if the automated search URL yields zero parsed cards, pause and ask you to run
# the search manually in the browser, then press Enter to re-parse the current page.
AIMM_MANUAL_SEARCH_FALLBACK=1

# 1 = loop: scroll (inner pane + window + mouse wheel), re-parse cards, merge unique
# /marketplace/item/ URLs (Facebook often keeps ~24 row nodes and swaps content). 0 = one parse only.
AIMM_FB_SERP_SCROLL=1

# Upper bound on parse+scroll cycles (safety cap).
AIMM_FB_SERP_SCROLL_MAX_ROUNDS=150

# Stop after this many consecutive cycles where no new unique listing URLs were found.
AIMM_FB_SERP_SCROLL_IDLE=6

# Seconds to wait after each scroll so new cards can render before re-parsing.
AIMM_FB_SERP_SCROLL_PAUSE=0.55
